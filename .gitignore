# Root .gitignore for Portfolio Builder

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment Variables
.env
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Build Artifacts
frontend/dist/
frontend/dist-ssr/
backend/dist/
backend/build/

# Prisma
backend/prisma/dev.db
backend/prisma/dev.db-journal

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor/System Files
.vscode/
.idea/
.DS_Store
Thumbs.db

# User Uploads (Production)
backend/uploads/*
!backend/uploads/.gitkeep
